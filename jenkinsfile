pipeline {
    agent {label "SPC" }

    triggers {
        pollSCM('* * * * *')
    }

    stages {
        stage('git checkout') {
            steps {
                git url : 'https://github.com/akhilonteru/spring-petclinic.git',
                branch : 'main'
            }
        }
        stage('build and scan'){
            steps {
                withCredentials([string(credentialsID:'sonar_id', varible: 'SONAR_TOKEN')]){
                withSonarQubeEnv('SONAR'){
                sh """ mvn clean package sonar:sonar \
                        -Dsonar.projectKey=DeepthiReddy7_spring-petclinic \
                        -Dsonar.organization=deepthireddy7 \
                        -Dsonar.host.url=https://sonarcloud.io \
                        -Dsonar.login=$SONAR_TOKEN
                    """
                }
                }
            }
        }
    }
}