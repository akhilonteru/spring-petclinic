pipeline {
    agent {label "SPC" }
    stages {
        stage('git checkout') {
            steps {
                git url : 'https://github.com/akhilonteru/spring-petclinic.git',
                branch : 'main'
            }
        }
        stage('build and scan'){
            steps {
                sh 'mv clean package sonar:sonar'
            }
        }
    }
}